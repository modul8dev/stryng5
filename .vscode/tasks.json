{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch:css",
      "type": "shell",
      "command": "npm run watch:css",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "."
        }
      },
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "group": "watchers"
      }
    }
  ]
}
