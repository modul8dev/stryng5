{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Django",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/webapp/manage.py",
            "preLaunchTask": "watch:css",
            "args": [
                "runserver"
            ],
            "django": true
        },
        {
            "name": "Q-Cluster",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/webapp/manage.py",
            "args": [
                "qcluster",
            ],
            "django": true,
            "gevent": true
        }
    ],
    "compounds": [
        {
            "name": "Django + Q-Cluster",
            "configurations": ["Python Debugger: Django", "Q-Cluster"],
            "stopAll": true
        }
    ]
}